# Meta Threads app credentials (https://developers.facebook.com/)
THREADS_APP_ID=
THREADS_APP_SECRET=

# Must exactly match a redirect URI configured in your Meta app settings.
# Local dev (Vite proxies /api to the Node server on port 3000):
THREADS_REDIRECT_URI=http://localhost:5173/api/threads/oauth/callback
# Production (Fly):
# THREADS_REDIRECT_URI=https://red-door.fly.dev/api/threads/oauth/callback

# Optional bootstrap token — normally you connect once via OAuth instead:
# /api/threads/oauth/start
THREADS_ACCESS_TOKEN=

# Where the server stores the long-lived token (auto-refreshed).
THREADS_DATA_DIR=./data

# Optional tuning
THREADS_POST_LIMIT=5
THREADS_CACHE_TTL_MS=300000
PORT=3000
